{
  "name": "devo",
  "displayName": "Devo",
  "description": "A Habbo-inspired cyberpunk incremental game inside VS Code",
  "version": "0.1.0",
  "publisher": "UrielLoaiza",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/devo"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "game",
    "incremental",
    "cyberpunk",
    "habbo",
    "pixel-art",
    "gamification"
  ],
  "galleryBanner": {
    "color": "#0f0f1a",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "devo.roomView",
          "name": "Devo"
        }
      ]
    },
    "commands": [
      {
        "command": "devo.reset",
        "title": "Devo: Reset Game Data"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:webview && npm run build:ext",
    "build:ext": "tsc -p tsconfig.json",
    "build:webview": "vite build",
    "watch": "tsc -watch -p tsconfig.json",
    "dev": "vite build --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "@vscode/vsce": "^3.0.0"
  },
  "dependencies": {
    "phaser": "^3.80.0"
  }
}
